# ============================================================
# NODE ENVIRONMENT
# ============================================================
# development | production | test
NODE_ENV=development

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
# Heartbeat timeout in milliseconds (how long to wait before considering a process dead)
HEARTBEAT_TIMEOUT=15000

# Restart delay in milliseconds (wait time before restarting a crashed process)
RESTART_DELAY=2000

# Job submission interval in milliseconds (how often to submit jobs)
SUBMIT_INTERVAL=3000

# Maximum number of jobs to submit
MAX_JOBS=10

# SQLite server startup timeout in milliseconds
SQLITE_TIMEOUT=10000

# ============================================================
# WORKER CONFIGURATION
# ============================================================
# Number of workers for each process type
ANALYZER_WORKERS=2
BROWSER_WORKERS=2
EXPORTER_WORKERS=1
SUBMITTER_WORKERS=5

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Path to SQLite database file
DB_PATH=./data/queue.db

# Enable WAL (Write-Ahead Logging) for better concurrency
DB_WAL=true

# SQLite sync mode: OFF | NORMAL | FULL
DB_SYNC=NORMAL

# Number of read workers in SQLite server
READ_WORKERS=3

# Number of write workers in SQLite server (should be 1)
WRITE_WORKERS=1

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Pretty print logs
LOG_PRETTY=true

# ============================================================
# PERFORMANCE PROFILING
# ============================================================
# Enable performance profiling (true | false)
PROFILE=false