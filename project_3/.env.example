# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=development

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
APP_NAME=scrape-flow
APP_VERSION=3.0.0
START_TIMEOUT=5000
SHUTDOWN_TIMEOUT=10000

# ============================================================
# WORKER CONFIGURATION
# ============================================================
MIN_WORKERS=4
MAX_WORKERS=16
SCALE_UP_THRESHOLD=100
SCALE_DOWN_THRESHOLD=10
SCALE_INTERVAL=5000
WORKER_IDLE_TIMEOUT=30000
HEARTBEAT_INTERVAL=3000
HEARTBEAT_TIMEOUT=30000

# ============================================================
# QUEUE CONFIGURATION
# ============================================================
VISIBILITY_TIMEOUT=30000
MAX_RETRIES=3
BATCH_SIZE=10
MAX_QUEUE_SIZE=10000
SWEEP_INTERVAL=1000

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_PATH=./data/queue.db
DB_WAL=true
DB_SYNC=NORMAL
READ_WORKERS=2
WRITE_WORKERS=2
DB_BATCH_SIZE=50
DB_CACHE_SIZE=2000
CHECKPOINT_INTERVAL=5000

# ============================================================
# PIPELINE CONFIGURATION
# ============================================================
SUBMIT_INTERVAL=1000
MAX_JOBS=50
PARALLEL_JOBS=10

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL=info
LOG_PRETTY=true
LOG_OUTPUT_DIR=./logs
LOG_MAX_FILES=10
LOG_MAX_SIZE=100m

# ============================================================
# PERFORMANCE PROFILING
# ============================================================
PROFILE=false
METRICS_INTERVAL=10000
SLOW_THRESHOLD=1000

# ============================================================
# EXPORT CONFIGURATION
# ============================================================
EXPORT_DIR=./exports
DB_EXPORT=false
API_EXPORT_URL=
# ============================================================
# PUPPETEER CONFIGURATION
# ============================================================
# Number of persistent tabs in browser
PUPPETEER_TABS=4

# Run browser in headless mode (false = visible browser)
PUPPETEER_HEADLESS=false

# Enable DevTools (true = open DevTools for each tab)
PUPPETEER_DEVTOOLS=true

# Navigation timeout in milliseconds
PUPPETEER_TIMEOUT=30000

# Enable debug mode
PUPPETEER_DEBUG=false